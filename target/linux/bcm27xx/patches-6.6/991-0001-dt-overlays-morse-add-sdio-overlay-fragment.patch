From 1d3399ea9dd9048775e8b53d9b2157993730ff7f Mon Sep 17 00:00:00 2001
From: Arien Judge <arien.judge@morsemicro.com>
Date: Tue, 6 Feb 2024 17:40:37 +1100
Subject: [PATCH 1/4] dt-overlays: morse: add sdio overlay fragment for RPi5 and older Pis

This overlay supports both:
- RPi5 (BCM2712 with RP1): Uses &rp1_mmc0 and RP1 pinctrl format
- RPi1-4 (BCM2835/6/7): Uses &mmc and BCM2835 pinctrl format

Both platforms use the same node name (mm6108_sdio@0) for user-space compatibility.
GPIOs (5, 17, 23, 24) are the same on the 40-pin header across all models.

---
 .../arm/boot/dts/overlays/mm_wlan-overlay.dts | 89 ++++++++++++++++++++
 1 file changed, 89 insertions(+)
 create mode 100644 arch/arm/boot/dts/overlays/mm_wlan-overlay.dts

diff --git a/arch/arm/boot/dts/overlays/mm_wlan-overlay.dts b/arch/arm/boot/dts/overlays/mm_wlan-overlay.dts
new file mode 100644
index 000000000..8c4a9f2e1
--- /dev/null
+++ b/arch/arm/boot/dts/overlays/mm_wlan-overlay.dts
@@ -0,0 +1,89 @@
+/dts-v1/;
+/plugin/;
+
+/ {
+	compatible = "brcm,bcm2835", "brcm,bcm2836", "brcm,bcm2708", "brcm,bcm2709", "brcm,bcm2711", "brcm,bcm2712";
+
+	/* Fragment for RPi1-4: Use &mmc (BCM2835/6/7 SD host) */
+	fragment@0 {
+		target = <&mmc>;
+		wifi_ovl: __overlay__ {
+			pinctrl-0 = <&sdio_ovl_pins &mm_sdio_pins>;
+			pinctrl-names = "default";
+			non-removable;
+			bus-width = <4>;
+			status = "okay";
+			#address-cells = <1>;
+			#size-cells = <0>;
+			mm6108_sdio: mm6108_sdio@0 {
+				compatible = "morse,mm610x";
+				reset-gpios = <&gpio 17 0>;
+				power-gpios = <&gpio 3 0>,
+				              <&gpio 7 0>;
+				status = "okay";
+				reg = <2>;
+				bus-width = <4>;
+			};
+		};
+	};
+
+	/* Fragment for RPi5: Use &rp1_mmc0 (RP1 SD host) */
+	fragment@1 {
+		target = <&rp1_mmc0>;
+		__overlay__ {
+			pinctrl-0 = <&rp1_sdio0_22_27 &mm_sdio_pins_rp1>;
+			pinctrl-names = "default";
+			non-removable;
+			bus-width = <4>;
+			status = "okay";
+			#address-cells = <1>;
+			#size-cells = <0>;
+			mm6108_sdio: mm6108_sdio@0 {
+				compatible = "morse,mm610x";
+				reset-gpios = <&gpio 17 0>;
+				power-gpios = <&gpio 3 0>,
+				              <&gpio 7 0>;
+				status = "okay";
+				reg = <2>;
+				bus-width = <4>;
+			};
+		};
+	};
+
+	/* Fragment for RPi5: Enable RP1 SDIO clock */
+	fragment@2 {
+		target = <&rp1_sdio_clk0>;
+		__overlay__ {
+			status = "okay";
+		};
+	};
+
+	/* BCM2835 pinctrl format for RPi1-4 */
+	fragment@3 {
+		target = <&gpio>;
+		__overlay__ {
+			sdio_ovl_pins: sdio_ovl_pins {
+				brcm,pins = <22 23 24 25 26 27>;
+				brcm,function = <7>; /* ALT3 = SD1 */
+				brcm,pull = <0 2 2 2 2 2>;
+			};
+			mm_sdio_pins: mm_sdio_pins {
+				brcm,pins = <1>; /* CHIP-IRQ */
+				brcm,function = <0>;
+				brcm,pull = <2>;
+			};
+		};
+	};
+
+	/* RP1 pinctrl format for RPi5 */
+	fragment@4 {
+		target = <&rp1_gpio>;
+		__overlay__ {
+			mm_sdio_pins_rp1: mm_sdio_pins {
+				pins = "gpio1";
+				function = "gpio";
+				bias-pull-up;
+			};
+		};
+	};
+};
