From: James Haggerty <james.haggerty@morsemicro.com>
Date: Fri, 28 Jun 2024 09:28:52 +1000
Subject: [PATCH] ARM: dts: bcm2711: Add morse HAT gpios to gpio-line-names

---
 arch/arm/boot/dts/broadcom/bcm2711-rpi-4-b.dts | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

--- a/arch/arm/boot/dts/broadcom/bcm2711-rpi-4-b.dts
+++ b/arch/arm/boot/dts/broadcom/bcm2711-rpi-4-b.dts
@@ -80,11 +80,11 @@
 	gpio-line-names = "ID_SDA",		/*  0 */
 			  "ID_SCL",
-			  "GPIO2",
-			  "GPIO3",
+			  "MM_WAKE",
+			  "MM_RESET",
 			  "GPIO4",
-			  "GPIO5",		/*  5 */
-			  "GPIO6",
+			  "MM_BUSY",		/*  5 */
+			  "GPIO6",
 			  "GPIO7",
 			  "GPIO8",
 			  "GPIO9",
