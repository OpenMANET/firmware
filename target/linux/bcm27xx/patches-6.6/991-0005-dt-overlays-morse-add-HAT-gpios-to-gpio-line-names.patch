From f34d45478594590a4b30fdff6968d258d5883919 Mon Sep 17 00:00:00 2001
From: James Haggerty <james.haggerty@morsemicro.com>
Date: Fri, 28 Jun 2024 09:28:52 +1000
Subject: [PATCH] ARM: dts: bcm2711: Add morse HAT gpios to gpio-line-names

---
 arch/arm/boot/dts/broadcom/bcm2711-rpi-4-b.dts | 6 +++---
 arch/arm/boot/dts/broadcom/bcm2711-rpi-cm4.dts | 6 +++---
 2 files changed, 6 insertions(+), 6 deletions(-)

--- a/arch/arm/boot/dts/broadcom/bcm2711-rpi-4-b.dts
+++ b/arch/arm/boot/dts/broadcom/bcm2711-rpi-4-b.dts
@@ -80,11 +80,11 @@
 	gpio-line-names = "ID_SDA",		/*  0 */
 			  "ID_SCL",
-			  "GPIO2",
-			  "GPIO3",
+			  "MM_WAKE",
+			  "MM_RESET",
 			  "GPIO4",
-			  "GPIO5",		/*  5 */
-			  "GPIO6",
+			  "MM_BUSY",		/*  5 */
+			  "GPIO6",
 			  "GPIO7",
 			  "GPIO8",
 			  "GPIO9",

+--- a/arch/arm/boot/dts/broadcom/bcm2711-rpi-cm4.dts
++++ b/arch/arm/boot/dts/broadcom/bcm2711-rpi-cm4.dts
+@@ -322,11 +322,11 @@
+ &gpio {
+ 	gpio-line-names = "ID_SDA",
+ 			  "ID_SCL",
+-			  "GPIO2",
+-			  "GPIO3",
++			  "MM_WAKE",
++			  "MM_RESET",
+ 			  "GPIO4",
+-			  "GPIO5",
++			  "MM_BUSY",
+ 			  "GPIO6",
+ 			  "GPIO7",
+ 			  "GPIO8",
+ 			  "GPIO9",
