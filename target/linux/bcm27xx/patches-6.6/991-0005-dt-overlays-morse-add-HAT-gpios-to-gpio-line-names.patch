From f34d45478594590a4b30fdff6968d258d5883919 Mon Sep 17 00:00:00 2001
From: James Haggerty <james.haggerty@morsemicro.com>
Date: Fri, 28 Jun 2024 09:28:52 +1000
Subject: [PATCH] ARM: dts: bcm2711: Add morse HAT gpios to gpio-line-names

---
 arch/arm/boot/dts/broadcom/bcm2710-rpi-3-b.dts       | 6 +++---
 arch/arm/boot/dts/broadcom/bcm2710-rpi-zero-2-w.dts  | 6 +++---
 arch/arm/boot/dts/broadcom/bcm2711-rpi-4-b.dts       | 6 +++---
 arch/arm/boot/dts/broadcom/bcm2711-rpi-cm4.dts       | 6 +++---
 arch/arm64/boot/dts/broadcom/bcm2712-rpi-5-b.dts     | 6 +++---
 arch/arm64/boot/dts/broadcom/bcm2712-rpi-cm5.dtsi    | 6 +++---
 6 files changed, 18 insertions(+), 18 deletions(-)

--- a/arch/arm/boot/dts/broadcom/bcm2710-rpi-3-b.dts
+++ b/arch/arm/boot/dts/broadcom/bcm2710-rpi-3-b.dts
@@ -32,11 +32,11 @@
 	gpio-line-names = "ID_SDA",
 			  "ID_SCL",
 			  "GPIO2",
-			  "GPIO3",
+			  "MM_WAKE",
 			  "GPIO4",
-			  "GPIO5",
+			  "MM_RESET",
 			  "GPIO6",
-			  "GPIO7",
+			  "MM_BUSY",
 			  "GPIO8",
 			  "GPIO9",
 			  "GPIO10",
--- a/arch/arm/boot/dts/broadcom/bcm2710-rpi-zero-2-w.dts
+++ b/arch/arm/boot/dts/broadcom/bcm2710-rpi-zero-2-w.dts
@@ -30,11 +30,11 @@
 	gpio-line-names = "ID_SDA",
 			  "ID_SCL",
 			  "GPIO2",
-			  "GPIO3",
+			  "MM_WAKE",
 			  "GPIO4",
-			  "GPIO5",
+			  "MM_RESET",
 			  "GPIO6",
-			  "GPIO7",
+			  "MM_BUSY",
 			  "GPIO8",
 			  "GPIO9",
 			  "GPIO10",
--- a/arch/arm/boot/dts/broadcom/bcm2711-rpi-4-b.dts
+++ b/arch/arm/boot/dts/broadcom/bcm2711-rpi-4-b.dts
@@ -81,11 +81,11 @@
 	gpio-line-names = "ID_SDA",		/*  0 */
 			  "ID_SCL",
 			  "GPIO2",
-			  "GPIO3",
+			  "MM_WAKE",
 			  "GPIO4",
-			  "GPIO5",		/*  5 */
+			  "MM_RESET",		/*  5 */
 			  "GPIO6",
-			  "GPIO7",
+			  "MM_BUSY",
 			  "GPIO8",
 			  "GPIO9",
 			  "GPIO10",		/* 10 */
--- a/arch/arm/boot/dts/broadcom/bcm2711-rpi-cm4.dts
+++ b/arch/arm/boot/dts/broadcom/bcm2711-rpi-cm4.dts
@@ -319,11 +319,11 @@
 	gpio-line-names = "ID_SDA",
 			  "ID_SCL",
 			  "GPIO2",
-			  "GPIO3",
+			  "MM_WAKE",
 			  "GPIO4",
-			  "GPIO5",
+			  "MM_RESET",
 			  "GPIO6",
-			  "GPIO7",
+			  "MM_BUSY",
 			  "GPIO8",
 			  "GPIO9",
 			  "GPIO10",
--- a/arch/arm64/boot/dts/broadcom/bcm2712-rpi-5-b.dts
+++ b/arch/arm64/boot/dts/broadcom/bcm2712-rpi-5-b.dts
@@ -682,11 +682,11 @@
         gpio-line-names =
                 "ID_SDA", // GPIO0
                 "ID_SCL", // GPIO1
                 "GPIO2", // GPIO2
-                "GPIO3", // GPIO3
+                "MM_WAKE", // GPIO3
                 "GPIO4", // GPIO4
-                "GPIO5", // GPIO5
+                "MM_RESET", // GPIO5
                 "GPIO6", // GPIO6
-                "GPIO7", // GPIO7
+                "MM_BUSY", // GPIO7
                 "GPIO8", // GPIO8
                 "GPIO9", // GPIO9
                 "GPIO10", // GPIO10
--- a/arch/arm64/boot/dts/broadcom/bcm2712-rpi-cm5.dtsi
+++ b/arch/arm64/boot/dts/broadcom/bcm2712-rpi-cm5.dtsi
@@ -675,11 +675,11 @@
         gpio-line-names =
                 "ID_SDA", // GPIO0
                 "ID_SCL", // GPIO1
                 "GPIO2", // GPIO2
-                "GPIO3", // GPIO3
+                "MM_WAKE", // GPIO3
                 "GPIO4", // GPIO4
-                "GPIO5", // GPIO5
+                "MM_RESET", // GPIO5
                 "GPIO6", // GPIO6
-                "GPIO7", // GPIO7
+                "MM_BUSY", // GPIO7
                 "GPIO8", // GPIO8
                 "GPIO9", // GPIO9
                 "GPIO10", // GPIO10
