From a7f068bc6332aa17a3be03cb69ad18c4c546eddf Mon Sep 17 00:00:00 2001
From: Sophronia Koilpillai <sophronia.koilpillai@morsemicro.com>
Date: Fri, 1 Nov 2024 10:55:11 +1100
Subject: [PATCH] bcm27xx: (APP-3660) Create separate SPI device tree overlay
 for MM610x and MM810x - Unified for RPi1-4 and RPi5

--- /dev/null
+++ b/arch/arm/boot/dts/overlays/mm610x-spi-overlay.dts
@@ -0,0 +1,142 @@
+/dts-v1/;
+/plugin/;
+
+/ {
+	compatible = "brcm,bcm2835", "brcm,bcm2836", "brcm,bcm2837",
+	             "brcm,bcm2708", "brcm,bcm2709", "brcm,bcm2710", "brcm,bcm2711", "brcm,bcm2712";
+
+	// Fragment for older Raspberry Pi models (RPi1-4) using BCM2835/6/7 SPI0
+	fragment@0 {
+		target = <&spi0>;
+		frag0: __overlay__ {
+			pinctrl-0 = <&spi0_pins &spi0_cs_pins &morse_wake &morse_busy &morse_irq &morse_reset>;
+			cs-gpios = <&gpio 8 1>;
+			#address-cells = <1>;
+			#size-cells = <0>;
+			status = "okay";
+
+			mm6108: mm6108@0 {
+				compatible = "morse,mm610x-spi";
+				reg = <0>; /* CE0 */
+				reset-gpios = <&gpio 17 0>;
+				power-gpios = <&gpio 23 0>,
+				              <&gpio 24 0>;
+				spi-irq-gpios = <&gpio 5 0>;
+				spi-max-frequency = <50000000>;
+				status = "okay";
+			};
+
+			spidev0: spidev@0 {
+				reg = <0>; /* CE0 */
+				status = "disabled";
+			};
+
+			spidev1: spidev@1 {
+				reg = <1>; /* CE1 */
+				status = "disabled";
+			};
+		};
+	};
+
+	// Fragment for Raspberry Pi 5 using RP1 SPI0
+	fragment@1 {
+		target = <&rp1_spi0>;
+		frag1: __overlay__ {
+			pinctrl-0 = <&rp1_spi0_gpio9 &rp1_spi0_cs_gpio7 &rp1_morse_wake &rp1_morse_busy &rp1_morse_irq &rp1_morse_reset>;
+			cs-gpios = <&rp1_gpio 8 1>;
+			#address-cells = <1>;
+			#size-cells = <0>;
+			status = "okay";
+
+			mm6108_rpi5: mm6108@0 {
+				compatible = "morse,mm610x-spi";
+				reg = <0>; /* CE0 */
+				reset-gpios = <&rp1_gpio 17 0>;
+				power-gpios = <&rp1_gpio 23 0>,
+				              <&rp1_gpio 24 0>;
+				spi-irq-gpios = <&rp1_gpio 5 0>;
+				spi-max-frequency = <50000000>;
+				status = "okay";
+			};
+		};
+	};
+
+	// GPIO pinctrl for older Raspberry Pi models (BCM2835 format)
+	fragment@2 {
+		target = <&gpio>;
+		__overlay__ {
+			spi0_cs_pins: spi0_cs_pins {
+				brcm,pins = <8>;
+				brcm,function = <1>; /* BCM2835_FSEL_GPIO_OUT */
+				brcm,pull = <2>;     /* SET SPI PINS AS PULL HIGH */
+			};
+			spi0_pins: spi0_pins {
+				brcm,pins = <9 10 11>;
+				brcm,function = <4>; /* BCM2835_FSEL_ALT0 (SPI0) */
+				brcm,pull = <2 2 2>; /* SET SPI PINS AS PULL HIGH */
+			};
+
+			morse_wake: morse_wake {
+				brcm,pins = <23>;
+				brcm,function = <0>; /* BCM2835_FSEL_GPIO_IN */
+				brcm,pull = <2>;     /* PULL UP */
+			};
+
+			morse_busy: morse_busy {
+				brcm,pins = <24>;
+				brcm,function = <0>; /* BCM2835_FSEL_GPIO_IN */
+				brcm,pull = <1>;     /* PULL DOWN */
+			};
+
+			morse_irq: morse_irq {
+				brcm,pins = <5>;
+				brcm,function = <0>; /* BCM2835_FSEL_GPIO_IN */
+				brcm,pull = <2>;     /* PULL UP */
+			};
+
+			morse_reset: morse_reset {
+				brcm,pins = <17>;
+				brcm,function = <0>; /* BCM2835_FSEL_GPIO_IN */
+				brcm,pull = <2>;     /* PULL UP */
+			};
+		};
+	};
+
+	// GPIO pinctrl for Raspberry Pi 5 (RP1 format) - custom pins for morse signals
+	fragment@3 {
+		target = <&rp1_gpio>;
+		__overlay__ {
+			rp1_morse_wake: rp1_morse_wake {
+				pin_wake {
+					function = "gpio";
+					pins = "gpio23";
+					bias-pull-up;
+				};
+			};
+
+			rp1_morse_busy: rp1_morse_busy {
+				pin_busy {
+					function = "gpio";
+					pins = "gpio24";
+					bias-pull-down;
+				};
+			};
+
+			rp1_morse_irq: rp1_morse_irq {
+				pin_irq {
+					function = "gpio";
+					pins = "gpio5";
+					bias-pull-up;
+				};
+			};
+
+			rp1_morse_reset: rp1_morse_reset {
+				pin_reset {
+					function = "gpio";
+					pins = "gpio17";
+					bias-pull-up;
+				};
+			};
+		};
+	};
+};
\ No newline at end of file
