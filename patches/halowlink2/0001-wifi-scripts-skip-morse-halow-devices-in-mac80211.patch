From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: ckleiner95 <ckleiner95@users.noreply.github.com>
Date: Mon, 24 Feb 2026 00:00:00 +0000
Subject: [PATCH] wifi-scripts: skip morse HaLow devices in mac80211

Prevent mac80211.uc from creating duplicate radio configuration for
morse HaLow devices. These devices are managed by morse.sh and should
not be picked up by the mac80211 wifi setup script.

Without this patch, both mac80211 and morse.sh attempt to manage the
same HaLow radio, causing conflicting wireless configurations.

Signed-off-by: ckleiner95 <ckleiner95@users.noreply.github.com>
---
 package/network/config/wifi-scripts/files/lib/wifi/mac80211.uc | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/package/network/config/wifi-scripts/files/lib/wifi/mac80211.uc b/package/network/config/wifi-scripts/files/lib/wifi/mac80211.uc
index e82525e2..04488ecb 100644
--- a/package/network/config/wifi-scripts/files/lib/wifi/mac80211.uc
+++ b/package/network/config/wifi-scripts/files/lib/wifi/mac80211.uc
@@ -36,6 +36,10 @@ for (let phy_name, phy in board.wlan) {
 	if (!info || !length(info.bands))
 		continue;

+	/* Skip morse (HaLow) devices - they are managed by morse.sh, not mac80211 */
+	if (match(readfile(`/sys/class/ieee80211/${phy_name}/device/uevent`) ?? "", /DRIVER=morse/))
+		continue;
+
 	let radios = length(info.radios) > 0 ? info.radios : [{ bands: info.bands }];
 	for (let radio in radios) {
 		while (config[`radio${idx}`])
--
