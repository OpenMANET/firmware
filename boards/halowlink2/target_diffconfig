CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_morse_halowlink2=y
CONFIG_TARGET_DEVICE_ramips_mt7621_DEVICE_morse_halowlink2=y

CONFIG_VERSION_MANUFACTURER="MorseMicro"
CONFIG_VERSION_PRODUCT="HaLowLink2"

CONFIG_PACKAGE_bsp-halowlink2=y
CONFIG_PACKAGE_morse-fw-8108=y
CONFIG_PACKAGE_kmod-morse=y
CONFIG_PACKAGE_kmod-mmc=y
CONFIG_PACKAGE_kmod-sdhci-mt7620=y
CONFIG_PACKAGE_kmod-mt7603=y
CONFIG_PACKAGE_netifd-morse=y
CONFIG_PACKAGE_libcap=y

# HaLow Link 2 uses MM8108 only - exclude MM6108 firmware
CONFIG_PACKAGE_morse-fw-6108=n
CONFIG_PACKAGE_morse-fw-6108-tlm=n

# Not needed for this board
CONFIG_PACKAGE_ftdi-usb-spi=n
CONFIG_PACKAGE_kmod-ftdi-usb-spi=n

# No audio hardware on this board
CONFIG_PACKAGE_alsa-ucm-conf=n
CONFIG_PACKAGE_alsa-utils=n

# Exclude WiFi firmware/drivers not used on this board
CONFIG_PACKAGE_ath10k-firmware-qca6174=n
CONFIG_PACKAGE_ath11k-firmware-wcn6855=n
CONFIG_PACKAGE_ath9k-htc-firmware=n
CONFIG_PACKAGE_iwlwifi-firmware-ax200=n
CONFIG_PACKAGE_iwlwifi-firmware-ax210=n
CONFIG_PACKAGE_kmod-ath10k=n
CONFIG_PACKAGE_kmod-ath11k=n
CONFIG_PACKAGE_kmod-ath11k-pci=n
CONFIG_PACKAGE_kmod-ath9k=n
CONFIG_PACKAGE_kmod-ath9k-common=n
CONFIG_PACKAGE_kmod-ath9k-htc=n
CONFIG_PACKAGE_kmod-iwlwifi=n
CONFIG_PACKAGE_kmod-mt7915e=n
CONFIG_PACKAGE_kmod-mt7915-firmware=n
CONFIG_PACKAGE_kmod-mt7916-firmware=n

# Exclude USB/misc firmware not needed
CONFIG_PACKAGE_edgeport-firmware=n
CONFIG_PACKAGE_r8152-firmware=n
CONFIG_PACKAGE_kmod-usb-serial-edgeport=n

# Exclude extra filesystem modules
CONFIG_PACKAGE_kmod-fs-ext4=n
CONFIG_PACKAGE_kmod-fs-f2fs=n

# Kernel support for RGB LEDs (PWM multicolor)
CONFIG_HIGH_RES_TIMERS=y
CONFIG_LEDS_CLASS_MULTICOLOR=y
CONFIG_LEDS_PWM_MULTICOLOR=y
CONFIG_PWM=y
CONFIG_PWM_GPIO=y
CONFIG_PWM_SYSFS=y
