CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_bcm27xx=y
CONFIG_TARGET_bcm27xx_bcm2710=y
CONFIG_TARGET_DEVICE_bcm27xx_bcm2710_DEVICE_bcm2710_mm6108-spi=y
CONFIG_TARGET_DEVICE_bcm27xx_bcm2710_DEVICE_bcm2710_ht-hc01p-spi=y
CONFIG_TARGET_DEVICE_bcm27xx_bcm2710_DEVICE_bcm2710_mm6108-sdio=y
CONFIG_TARGET_DEVICE_bcm27xx_bcm2710_DEVICE_bcm2710_mm8108-spi=y

CONFIG_VERSION_MANUFACTURER="Raspberry Pi"
CONFIG_VERSION_PRODUCT="BCM2710"

CONFIG_PACKAGE_morsectrl=y
CONFIG_PACKAGE_morse-fw-6108=y
CONFIG_PACKAGE_morse-fw-8108=y
CONFIG_PACKAGE_morse-fw-6108-tlm=m
CONFIG_PACKAGE_morse-fw-8108-tlm=m
CONFIG_PACKAGE_morse-fw-8108-flm=m
CONFIG_PACKAGE_morse-board-config-hotplug-model=y
CONFIG_PACKAGE_luci-app-ekhwizards=y

CONFIG_PACKAGE_bsp-bcm271x=y

#CONFIG_MORSE_REGDB_COUNTRY_CODE_FILTER="US"
#CONFIG_MORSE_REGDB_CHANNEL_NEGATIVE_FILTER="1|2|50|51"

CONFIG_TARGET_ROOTFS_PARTSIZE=1024

# Video encode/decode
CONFIG_PACKAGE_kmod-video-core=y
CONFIG_PACKAGE_kmod-video-codec-bcm2835=y

# bug with lan78xx - enabled by default for rpi4 platforms.
# We enable of-mdio to work around the dependency chain.
CONFIG_PACKAGE_kmod-of-mdio=y
# Disable ext4 image creation.
CONFIG_TARGET_ROOTFS_EXT4FS=n
