CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_bcm27xx=y
CONFIG_TARGET_bcm27xx_bcm2712=y
CONFIG_TARGET_DEVICE_bcm27xx_bcm2712_DEVICE_rpi-5=y
CONFIG_TARGET_DEVICE_bcm27xx_bcm2712_DEVICE_bcm2712_mm6108-spi=y
CONFIG_TARGET_DEVICE_bcm27xx_bcm2712_DEVICE_bcm2712_ht-hc01p-spi=y
CONFIG_TARGET_DEVICE_bcm27xx_bcm2712_DEVICE_bcm2712_mm6108-sdio=y
CONFIG_TARGET_DEVICE_bcm27xx_bcm2712_DEVICE_bcm2712_mm8108-spi=y
CONFIG_TARGET_DEVICE_bcm27xx_bcm2712_DEVICE_bcm2712_mm8108-sdio=y

CONFIG_VERSION_MANUFACTURER="Raspberry Pi"
CONFIG_VERSION_PRODUCT="BCM2712"

CONFIG_PACKAGE_morsectrl=y
CONFIG_PACKAGE_morse-fw-6108=y
CONFIG_PACKAGE_morse-fw-6108-tlm=y
CONFIG_PACKAGE_morse-fw-8108-tlm=y
CONFIG_PACKAGE_morse-fw-8108-flm=y
CONFIG_PACKAGE_morse-board-config-hotplug-model=y
CONFIG_PACKAGE_luci-app-ekhwizards=y

CONFIG_PACKAGE_bsp-bcm271x=y

CONFIG_TARGET_ROOTFS_PARTSIZE=4092
CONFIG_PACKAGE_persistent-vars-storage-bcm2712=y

# Video encode/decode
CONFIG_PACKAGE_kmod-video-core=y
CONFIG_PACKAGE_kmod-video-codec-bcm2835=y

# Enabling CONFIG_ALL_KMODS triggered a package installation
# bug with lan78xx - enabled by default for rpi4 platforms.
# We enable of-mdio to work around the dependency chain.
CONFIG_PACKAGE_kmod-of-mdio=y
# Disable ext4 image creation.
CONFIG_TARGET_ROOTFS_EXT4FS=n