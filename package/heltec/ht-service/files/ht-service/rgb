#!/bin/sh

# HT-HD01-V2 RGB LED control (kernel 6.6)
# Red:   GPIO 44 — claimed by LED subsystem, use brightness
# Green: GPIO 18 — sysfs 530, active low
# Blue:  GPIO 17 — sysfs 529, active low

RLED=/sys/class/leds/fuchsia:status/brightness
gled=530
bled=529

r_on() { echo 1 > $RLED; }
r_off() { echo 0 > $RLED; }

case $1 in
"r")
	r_on
	gpio $gled  1
	gpio $bled  1
	;;
"g")
	r_off
	gpio $gled  0
	gpio $bled  1
	;;
"b")
	r_off
	gpio $gled  1
	gpio $bled  0
	;;
"p")
	r_on
	gpio $gled  1
	gpio $bled  0
	;;
"y")
	r_on
	gpio $gled  0
	gpio $bled  1
	;;
"c")
	r_off
	gpio $gled  0
	gpio $bled  0
	;;
"w")
	r_on
	gpio $gled  0
	gpio $bled  0
	;;
"n")
	r_off
	gpio $gled  1
	gpio $bled  1
	;;
esac
